# Copy this file to .env and fill in the values for local development.
# On Render, set these as environment variables in the dashboard or render.yaml.

# Port the Express server listens on (Render overrides this automatically)
PORT=3001

# Path to the SQLite database file
# On Render free tier this is ephemeral — data resets on each deploy/restart.
# For persistence, attach a Render Disk and set this to /var/data/expenses.db
DB_PATH=./expenses.db

# Set to "production" on Render (enables static file serving of the frontend)
NODE_ENV=development
